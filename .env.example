# Copy to `.env` and adjust as needed. `docker compose` auto-loads .env.

# Host port mapping (change if the default conflicts locally)
FRONTEND_PORT=3000
BACKEND_PORT=8000
MONGO_PORT=27017
REDIS_PORT=6379

# App env
APP_ENV=production

# MongoDB
MONGO_USER=mongo
MONGO_PASSWORD=mongo
MONGO_DB=ai_platform
