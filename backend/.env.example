APP_NAME="AI Platform Backend"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000

UPLOAD_DIR=./storage/uploads
EXTRACTED_DIR=./storage/extracted
STANDARD_DETAILS_DIR=./storage/standard_details
MAX_UPLOAD_SIZE_MB=50

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Database + Redis (wired when persistence lands)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_platform
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# AI providers
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=asia-south1
COHERE_API_KEY=

# Feature flags (comma-separated). Available: validation_sd, validation_dd, validation_gfc,
# site_agent, chatbot, ocr_document_ai, vector_store_vertex
FEATURE_FLAGS=validation_sd,site_agent
